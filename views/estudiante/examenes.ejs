<!-- Mis Exámenes -->
<div class="hidden lg:block mb-8">
  <h1 class="text-2xl font-bold text-slate-800">Mis Exámenes</h1>
  <p class="text-slate-500 mt-1">Historial completo de tus evaluaciones</p>
</div>

<% if (resultados.length === 0) { %>
<div class="card text-center py-12">
  <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
  <h3 class="text-lg font-medium text-slate-600">No tienes exámenes registrados</h3>
  <p class="text-sm text-slate-400 mt-1">Cuando el administrador cargue tus resultados, aparecerán aquí.</p>
</div>
<% } else { %>

<!-- Resumen general -->
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-6">
  <% 
    const notas = resultados.map(r => parseFloat(r.nota_vigesimal));
    const promedio = (notas.reduce((a, b) => a + b, 0) / notas.length).toFixed(2);
    const mejor = Math.max(...notas).toFixed(2);
    const totalAprobados = notas.filter(n => n >= 11).length;
  %>
  <div class="card flex items-center gap-4">
    <div class="w-12 h-12 rounded-lg bg-primary-50 text-primary-600 flex items-center justify-center shrink-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-slate-800"><%= promedio %></p>
      <p class="text-xs text-slate-500">Promedio general</p>
    </div>
  </div>
  <div class="card flex items-center gap-4">
    <div class="w-12 h-12 rounded-lg bg-green-50 text-green-600 flex items-center justify-center shrink-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-slate-800"><%= totalAprobados %>/<%= resultados.length %></p>
      <p class="text-xs text-slate-500">Aprobados (≥11)</p>
    </div>
  </div>
  <div class="card flex items-center gap-4">
    <div class="w-12 h-12 rounded-lg bg-yellow-50 text-yellow-600 flex items-center justify-center shrink-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-slate-800"><%= mejor %></p>
      <p class="text-xs text-slate-500">Mejor nota</p>
    </div>
  </div>
</div>

<!-- Tabla de exámenes -->
<div class="card">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-slate-200">
          <th class="table-header">#</th>
          <th class="table-header">Examen</th>
          <th class="table-header">Tipo</th>
          <th class="table-header">Fecha</th>
          <th class="table-header text-center">Correctas</th>
          <th class="table-header text-center">Incorrectas</th>
          <th class="table-header text-center">En Blanco</th>
          <th class="table-header text-right">Puntaje Bruto</th>
          <th class="table-header text-right">Nota</th>
          <th class="table-header text-center">Ranking</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% resultados.forEach(function(r, idx) { 
          const nota = parseFloat(r.nota_vigesimal);
          const ranking = rankingsPorExamen[r.examen_id];
        %>
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="table-cell text-slate-400 font-mono text-xs"><%= idx + 1 %></td>
          <td class="table-cell">
            <div class="font-medium text-slate-800"><%= r.examen.descripcion || `Examen #${r.examen.id}` %></div>
            <div class="text-xs text-slate-400"><%= r.examen.total_preguntas %> preguntas</div>
          </td>
          <td class="table-cell">
            <span class="<%= r.examen.tipo === 'aptitud' ? 'badge-blue' : 'badge-green' %>">
              <%= r.examen.tipo === 'aptitud' ? 'Aptitud' : 'Conocimientos' %>
            </span>
          </td>
          <td class="table-cell text-slate-500"><%= new Date(r.examen.fecha).toLocaleDateString('es-PE', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
          <td class="table-cell text-center"><span class="text-green-600 font-semibold"><%= r.correctas %></span></td>
          <td class="table-cell text-center"><span class="text-red-500 font-semibold"><%= r.incorrectas %></span></td>
          <td class="table-cell text-center"><span class="text-slate-400"><%= r.en_blanco %></span></td>
          <td class="table-cell text-right font-mono text-sm"><%= parseFloat(r.puntaje_bruto).toFixed(2) %></td>
          <td class="table-cell text-right">
            <span class="text-lg font-bold <%= nota >= 14 ? 'text-green-600' : nota >= 11 ? 'text-yellow-600' : 'text-red-500' %>">
              <%= nota.toFixed(2) %>
            </span>
          </td>
          <td class="table-cell text-center">
            <% if (ranking) { %>
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold
              <%= ranking.posicion <= 3 ? 'bg-yellow-100 text-yellow-800' : 'bg-slate-100 text-slate-600' %>">
              <%= ranking.posicion %>°
            </span>
            <div class="text-xs text-slate-400 mt-0.5">de <%= ranking.total %></div>
            <% } else { %>
            <span class="text-slate-400">--</span>
            <% } %>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Detalle por examen (cards para mobile) -->
<div class="lg:hidden space-y-4 mt-6">
  <% resultados.forEach(function(r) { 
    const nota = parseFloat(r.nota_vigesimal);
    const ranking = rankingsPorExamen[r.examen_id];
    const porcentaje = (nota / 20 * 100).toFixed(0);
    const color = nota >= 14 ? 'bg-green-500' : nota >= 11 ? 'bg-yellow-500' : 'bg-red-500';
  %>
  <div class="card">
    <div class="flex items-start justify-between mb-3">
      <div>
        <h4 class="font-semibold text-slate-800"><%= r.examen.descripcion || `Examen #${r.examen.id}` %></h4>
        <p class="text-xs text-slate-400"><%= new Date(r.examen.fecha).toLocaleDateString('es-PE', { day: '2-digit', month: 'long', year: 'numeric' }) %></p>
      </div>
      <span class="text-2xl font-bold <%= nota >= 14 ? 'text-green-600' : nota >= 11 ? 'text-yellow-600' : 'text-red-500' %>"><%= nota.toFixed(2) %></span>
    </div>
    <div class="w-full bg-slate-100 rounded-full h-2 mb-3">
      <div class="<%= color %> rounded-full h-2" style="width: <%= porcentaje %>%"></div>
    </div>
    <div class="grid grid-cols-3 gap-2 text-center text-xs">
      <div class="px-2 py-1.5 rounded bg-green-50">
        <span class="block font-bold text-green-700"><%= r.correctas %></span>
        <span class="text-green-600">Correctas</span>
      </div>
      <div class="px-2 py-1.5 rounded bg-red-50">
        <span class="block font-bold text-red-700"><%= r.incorrectas %></span>
        <span class="text-red-600">Incorrectas</span>
      </div>
      <div class="px-2 py-1.5 rounded bg-slate-50">
        <span class="block font-bold text-slate-700"><%= r.en_blanco %></span>
        <span class="text-slate-500">En blanco</span>
      </div>
    </div>
    <% if (ranking) { %>
    <div class="mt-3 pt-3 border-t border-slate-100 flex items-center justify-between text-xs">
      <span class="text-slate-500">Ranking en este examen</span>
      <span class="font-bold text-slate-700"><%= ranking.posicion %>° de <%= ranking.total %></span>
    </div>
    <% } %>
  </div>
  <% }); %>
</div>
<% } %>
