<!-- Mis Exámenes -->
<div class="hidden lg:block mb-8">
  <h1 class="text-2xl font-bold text-slate-800">Mis Exámenes</h1>
  <p class="text-slate-500 mt-1">Historial completo de tus evaluaciones</p>
</div>

<% if (resultados.length === 0) { %>
<div class="card text-center py-12">
  <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
  <h3 class="text-lg font-medium text-slate-600">No tienes exámenes registrados</h3>
  <p class="text-sm text-slate-400 mt-1">Cuando el administrador cargue tus resultados, aparecerán aquí.</p>
</div>
<% } else { %>

<!-- Resumen general -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <% 
    const notas = resultados.map(r => parseFloat(r.nota_vigesimal));
    const promedio = (notas.reduce((a, b) => a + b, 0) / notas.length).toFixed(2);
    const mejor = Math.max(...notas).toFixed(2);
    const totalAprobados = notas.filter(n => n >= 11).length;
    const totalCorrectas = resultados.reduce((s, r) => s + r.correctas, 0);
    const totalPreguntas = resultados.reduce((s, r) => s + (r.examen.total_preguntas || 0), 0);
    const pctAciertosGlobal = totalPreguntas > 0 ? (totalCorrectas / totalPreguntas * 100).toFixed(1) : '0.0';
    const totalBlancoGlobal = resultados.reduce((s, r) => s + r.en_blanco, 0);
    const pctBlancoGlobal = totalPreguntas > 0 ? (totalBlancoGlobal / totalPreguntas * 100).toFixed(1) : '0.0';
  %>
  <div class="card flex items-center gap-4">
    <div class="w-12 h-12 rounded-lg bg-primary-50 text-primary-600 flex items-center justify-center shrink-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-slate-800"><%= promedio %></p>
      <p class="text-xs text-slate-500">Promedio general</p>
    </div>
  </div>
  <div class="card flex items-center gap-4">
    <div class="w-12 h-12 rounded-lg bg-green-50 text-green-600 flex items-center justify-center shrink-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-slate-800"><%= pctAciertosGlobal %>%</p>
      <p class="text-xs text-slate-500">Promedio de aciertos</p>
    </div>
  </div>
  <div class="card flex items-center gap-4">
    <div class="w-12 h-12 rounded-lg bg-slate-50 text-slate-500 flex items-center justify-center shrink-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"/></svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-slate-800"><%= pctBlancoGlobal %>%</p>
      <p class="text-xs text-slate-500">Dejadas en blanco</p>
    </div>
  </div>
  <div class="card flex items-center gap-4">
    <div class="w-12 h-12 rounded-lg bg-yellow-50 text-yellow-600 flex items-center justify-center shrink-0">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
    </div>
    <div>
      <p class="text-2xl font-bold text-slate-800"><%= mejor %></p>
      <p class="text-xs text-slate-500">Mejor nota</p>
    </div>
  </div>
</div>

<!-- Tabla de exámenes -->
<div class="card">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr class="border-b border-slate-200">
          <th class="table-header">#</th>
          <th class="table-header">Examen</th>
          <th class="table-header">Tipo</th>
          <th class="table-header">Fecha</th>
          <th class="table-header text-center">C / I / B</th>
          <th class="table-header text-center">% Aciertos</th>
          <th class="table-header text-right">Nota</th>
          <th class="table-header text-center">Ranking</th>
          <th class="table-header text-center">Detalle</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% resultados.forEach(function(r, idx) { 
          const nota = parseFloat(r.nota_vigesimal);
          const ranking = rankingsPorExamen[r.examen_id];
          const totalPreg = r.examen.total_preguntas || 1;
          const pctCorr = (r.correctas / totalPreg * 100).toFixed(1);
          const pctIncorr = (r.incorrectas / totalPreg * 100).toFixed(1);
          const pctBlanco = (r.en_blanco / totalPreg * 100).toFixed(1);
        %>
        <tr class="hover:bg-slate-50 transition-colors">
          <td class="table-cell text-slate-400 font-mono text-xs"><%= idx + 1 %></td>
          <td class="table-cell">
            <div class="font-medium text-slate-800"><%= r.examen.descripcion || `Examen #${r.examen.id}` %></div>
            <div class="text-xs text-slate-400"><%= r.examen.total_preguntas %> preguntas</div>
          </td>
          <td class="table-cell">
            <span class="<%= r.examen.tipo === 'aptitud' ? 'badge-blue' : 'badge-green' %>">
              <%= r.examen.tipo === 'aptitud' ? 'Aptitud' : 'Conocimientos' %>
            </span>
          </td>
          <td class="table-cell text-slate-500"><%= new Date(r.examen.fecha).toLocaleDateString('es-PE', { day: '2-digit', month: 'short', year: 'numeric' }) %></td>
          <td class="table-cell text-center">
            <span class="text-green-600 font-semibold"><%= r.correctas %></span> /
            <span class="text-red-500 font-semibold"><%= r.incorrectas %></span> /
            <span class="text-slate-400"><%= r.en_blanco %></span>
          </td>
          <td class="table-cell text-center">
            <span class="text-sm font-bold <%= parseFloat(pctCorr) >= 60 ? 'text-green-600' : parseFloat(pctCorr) >= 40 ? 'text-yellow-600' : 'text-red-500' %>"><%= pctCorr %>%</span>
          </td>
          <td class="table-cell text-right">
            <span class="text-lg font-bold <%= nota >= 14 ? 'text-green-600' : nota >= 11 ? 'text-yellow-600' : 'text-red-500' %>">
              <%= nota.toFixed(2) %>
            </span>
          </td>
          <td class="table-cell text-center">
            <% if (ranking) { %>
            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold
              <%= ranking.posicion <= 3 ? 'bg-yellow-100 text-yellow-800' : 'bg-slate-100 text-slate-600' %>">
              <%= ranking.posicion %>°
            </span>
            <div class="text-xs text-slate-400 mt-0.5">de <%= ranking.total %></div>
            <% } else { %>
            <span class="text-slate-400">--</span>
            <% } %>
          </td>
          <td class="table-cell text-center">
            <button onclick="toggleDetalle(<%= idx %>)" class="inline-flex items-center justify-center w-8 h-8 rounded-lg bg-primary-50 text-primary-600 hover:bg-primary-100 transition-colors">
              <svg class="w-4 h-4 transition-transform" id="iconDetalle<%= idx %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
          </td>
        </tr>
        <!-- Fila expandible de análisis -->
        <tr id="detalle<%= idx %>" class="hidden">
          <td colspan="9" class="p-0">
            <div class="bg-slate-50 border-y border-slate-200 p-5">
              <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
                <!-- Doughnut Chart -->
                <div class="flex flex-col items-center">
                  <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Distribución de Respuestas</h4>
                  <div class="relative w-44 h-44">
                    <canvas id="doughnut<%= idx %>"
                      data-correctas="<%= pctCorr %>"
                      data-incorrectas="<%= pctIncorr %>"
                      data-blanco="<%= pctBlanco %>">
                    </canvas>
                  </div>
                </div>

                <!-- Porcentajes detallados -->
                <div>
                  <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Desglose</h4>
                  <div class="space-y-3">
                    <div>
                      <div class="flex items-center justify-between mb-1">
                        <span class="text-sm text-slate-600">Correctas</span>
                        <span class="text-sm font-bold text-green-600"><%= pctCorr %>%</span>
                      </div>
                      <div class="w-full bg-slate-200 rounded-full h-2">
                        <div class="bg-green-500 rounded-full h-2" style="width: <%= pctCorr %>%"></div>
                      </div>
                    </div>
                    <div>
                      <div class="flex items-center justify-between mb-1">
                        <span class="text-sm text-slate-600">Incorrectas</span>
                        <span class="text-sm font-bold text-red-500"><%= pctIncorr %>%</span>
                      </div>
                      <div class="w-full bg-slate-200 rounded-full h-2">
                        <div class="bg-red-500 rounded-full h-2" style="width: <%= pctIncorr %>%"></div>
                      </div>
                    </div>
                    <div>
                      <div class="flex items-center justify-between mb-1">
                        <span class="text-sm text-slate-600">En blanco</span>
                        <span class="text-sm font-bold text-slate-500"><%= pctBlanco %>%</span>
                      </div>
                      <div class="w-full bg-slate-200 rounded-full h-2">
                        <div class="bg-slate-400 rounded-full h-2" style="width: <%= pctBlanco %>%"></div>
                      </div>
                    </div>
                  </div>

                  <!-- Análisis de estrategia -->
                  <div class="mt-4 p-3 rounded-lg bg-white border border-slate-200">
                    <h5 class="text-xs font-semibold text-slate-500 mb-2">Análisis de Estrategia</h5>
                    <div class="space-y-1 text-xs text-slate-600">
                      <% if (parseFloat(pctCorr) >= 60) { %>
                      <p>✅ Buen porcentaje de aciertos (<%= pctCorr %>%)</p>
                      <% } else if (parseFloat(pctCorr) >= 40) { %>
                      <p>⚠️ Porcentaje de aciertos moderado (<%= pctCorr %>%)</p>
                      <% } else { %>
                      <p>❌ Bajo porcentaje de aciertos (<%= pctCorr %>%) — refuerza los temas</p>
                      <% } %>

                      <% if (parseFloat(pctBlanco) > 20) { %>
                      <p>📝 Dejaste <%= pctBlanco %>% en blanco — intenta responder más preguntas</p>
                      <% } else if (parseFloat(pctBlanco) > 0) { %>
                      <p>📝 Solo <%= pctBlanco %>% en blanco — buen ritmo de respuesta</p>
                      <% } else { %>
                      <p>📝 Respondiste todas las preguntas</p>
                      <% } %>

                      <% if (parseFloat(pctIncorr) <= 15) { %>
                      <p>🎯 Solo <%= pctIncorr %>% de error — excelente control</p>
                      <% } else if (parseFloat(pctIncorr) >= 40) { %>
                      <p>🎯 <%= pctIncorr %>% de errores — revisa los temas antes de responder</p>
                      <% } %>
                    </div>
                  </div>
                </div>

                <!-- Comparación vs promedio general -->
                <div id="comparacion<%= idx %>"
                  data-examen-id="<%= r.examen_id %>"
                  data-mi-corr="<%= pctCorr %>"
                  data-mi-incorr="<%= pctIncorr %>"
                  data-mi-blanco="<%= pctBlanco %>">
                  <h4 class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Tú vs Promedio General</h4>
                  <div class="space-y-3" id="compBars<%= idx %>">
                    <!-- Se llena por JS -->
                  </div>
                </div>
              </div>
            </div>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>
</div>

<!-- Detalle por examen (cards para mobile) -->
<div class="lg:hidden space-y-4 mt-6">
  <% resultados.forEach(function(r) { 
    const nota = parseFloat(r.nota_vigesimal);
    const ranking = rankingsPorExamen[r.examen_id];
    const porcentaje = (nota / 20 * 100).toFixed(0);
    const color = nota >= 14 ? 'bg-green-500' : nota >= 11 ? 'bg-yellow-500' : 'bg-red-500';
    const totalPregM = r.examen.total_preguntas || 1;
    const pctCorrM = (r.correctas / totalPregM * 100).toFixed(1);
    const pctIncorrM = (r.incorrectas / totalPregM * 100).toFixed(1);
    const pctBlancoM = (r.en_blanco / totalPregM * 100).toFixed(1);
  %>
  <div class="card">
    <div class="flex items-start justify-between mb-3">
      <div>
        <h4 class="font-semibold text-slate-800"><%= r.examen.descripcion || `Examen #${r.examen.id}` %></h4>
        <p class="text-xs text-slate-400"><%= new Date(r.examen.fecha).toLocaleDateString('es-PE', { day: '2-digit', month: 'long', year: 'numeric' }) %></p>
      </div>
      <span class="text-2xl font-bold <%= nota >= 14 ? 'text-green-600' : nota >= 11 ? 'text-yellow-600' : 'text-red-500' %>"><%= nota.toFixed(2) %></span>
    </div>
    <div class="w-full bg-slate-100 rounded-full h-2 mb-3">
      <div class="<%= color %> rounded-full h-2" style="width: <%= porcentaje %>%"></div>
    </div>
    <div class="grid grid-cols-3 gap-2 text-center text-xs">
      <div class="px-2 py-1.5 rounded bg-green-50">
        <span class="block font-bold text-green-700"><%= pctCorrM %>%</span>
        <span class="text-green-600">Correctas</span>
      </div>
      <div class="px-2 py-1.5 rounded bg-red-50">
        <span class="block font-bold text-red-700"><%= pctIncorrM %>%</span>
        <span class="text-red-600">Incorrectas</span>
      </div>
      <div class="px-2 py-1.5 rounded bg-slate-50">
        <span class="block font-bold text-slate-700"><%= pctBlancoM %>%</span>
        <span class="text-slate-500">En blanco</span>
      </div>
    </div>
    <% if (ranking) { %>
    <div class="mt-3 pt-3 border-t border-slate-100 flex items-center justify-between text-xs">
      <span class="text-slate-500">Ranking en este examen</span>
      <span class="font-bold text-slate-700"><%= ranking.posicion %>° de <%= ranking.total %></span>
    </div>
    <% } %>
  </div>
  <% }); %>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
const promediosPorExamen = <%- promediosPorExamen %>;
const doughnutCharts = {};

function toggleDetalle(idx) {
  const row = document.getElementById('detalle' + idx);
  const icon = document.getElementById('iconDetalle' + idx);
  const isHidden = row.classList.contains('hidden');
  
  row.classList.toggle('hidden');
  icon.style.transform = isHidden ? 'rotate(180deg)' : '';

  // Crear doughnut chart si no existe
  if (isHidden && !doughnutCharts[idx]) {
    const canvas = document.getElementById('doughnut' + idx);
    const corr = parseFloat(canvas.dataset.correctas);
    const incorr = parseFloat(canvas.dataset.incorrectas);
    const blanco = parseFloat(canvas.dataset.blanco);

    doughnutCharts[idx] = new Chart(canvas, {
      type: 'doughnut',
      data: {
        labels: ['Correctas', 'Incorrectas', 'En blanco'],
        datasets: [{
          data: [corr, incorr, blanco],
          backgroundColor: ['#22c55e', '#ef4444', '#cbd5e1'],
          borderWidth: 0,
          spacing: 2
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: '65%',
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: '#1e293b',
            padding: 10,
            cornerRadius: 8,
            callbacks: {
              label: function(ctx) {
                return ctx.label + ': ' + ctx.parsed.toFixed(1) + '%';
              }
            }
          }
        }
      }
    });

    // Llenar comparación vs promedio
    const compDiv = document.getElementById('comparacion' + idx);
    const examenId = compDiv.dataset.examenId;
    const miCorr = parseFloat(compDiv.dataset.miCorr);
    const miIncorr = parseFloat(compDiv.dataset.miIncorr);
    const miBlanco = parseFloat(compDiv.dataset.miBlanco);
    const avgData = promediosPorExamen[examenId];
    const barsDiv = document.getElementById('compBars' + idx);

    if (avgData) {
      const items = [
        { label: 'Correctas', mi: miCorr, avg: parseFloat(avgData.pctCorrectasAvg), color: 'green', colorBg: 'bg-green-500', colorBgLight: 'bg-green-200' },
        { label: 'Incorrectas', mi: miIncorr, avg: parseFloat(avgData.pctIncorrectasAvg), color: 'red', colorBg: 'bg-red-500', colorBgLight: 'bg-red-200' },
        { label: 'En blanco', mi: miBlanco, avg: parseFloat(avgData.pctBlancoAvg), color: 'slate', colorBg: 'bg-slate-400', colorBgLight: 'bg-slate-200' }
      ];

      barsDiv.innerHTML = items.map(item => {
        const diff = (item.mi - item.avg).toFixed(1);
        const isPositive = item.label === 'Correctas' ? diff >= 0 : diff <= 0;
        const diffColor = isPositive ? 'text-green-600' : 'text-red-500';
        const diffSign = diff >= 0 ? '+' : '';
        return `
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-xs text-slate-600">${item.label}</span>
              <span class="text-xs font-semibold ${diffColor}">${diffSign}${diff}%</span>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex-1">
                <div class="flex items-center gap-1 mb-0.5">
                  <span class="text-[10px] text-slate-400 w-6">Tú</span>
                  <div class="flex-1 bg-slate-100 rounded-full h-1.5">
                    <div class="${item.colorBg} rounded-full h-1.5" style="width: ${Math.min(item.mi, 100)}%"></div>
                  </div>
                  <span class="text-[10px] font-semibold text-slate-600 w-10 text-right">${item.mi}%</span>
                </div>
                <div class="flex items-center gap-1">
                  <span class="text-[10px] text-slate-400 w-6">Avg</span>
                  <div class="flex-1 bg-slate-100 rounded-full h-1.5">
                    <div class="${item.colorBgLight} rounded-full h-1.5" style="width: ${Math.min(item.avg, 100)}%"></div>
                  </div>
                  <span class="text-[10px] text-slate-400 w-10 text-right">${item.avg}%</span>
                </div>
              </div>
            </div>
          </div>`;
      }).join('');
    }
  }
}
</script>
<% } %>
