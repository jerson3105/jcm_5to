<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — PIU Mariátegui</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
</head>
<body class="min-h-screen bg-gradient-to-br from-primary-950 via-primary-900 to-primary-800 flex items-center justify-center p-4" style="font-family: 'Inter', sans-serif;">

  <div class="w-full max-w-lg">
    <!-- Header -->
    <div class="text-center mb-6">
      <img src="/img/logo-blanco.png" alt="PIU Mariátegui" class="w-16 h-16 rounded-2xl object-contain bg-white/10 backdrop-blur border border-white/20 mx-auto mb-4">
      <h1 class="text-2xl font-extrabold text-white tracking-tight">¡Bienvenido, <%= nombre %>!</h1>
      <p class="text-primary-200 mt-2 text-sm">Antes de continuar, selecciona tu área y carrera de preferencia.</p>
    </div>

    <!-- Card principal -->
    <div class="bg-white rounded-2xl shadow-xl p-6 sm:p-8">
      <!-- Nota importante -->
      <div class="mb-6 p-4 bg-gold-50 border border-gold-200 rounded-xl">
        <div class="flex gap-3">
          <div class="shrink-0 mt-0.5">
            <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-gold-800 mb-1">IMPORTANTE</p>
            <p class="text-xs text-gold-700 leading-relaxed">En caso de no encontrar la especialidad de su preferencia, elija el área a fin de su especialidad. <span class="font-semibold">Ejemplo:</span> Ingeniería Industrial → elijo el <span class="font-bold">ÁREA C</span>.</p>
          </div>
        </div>
      </div>

      <form action="/estudiante/elegir-carrera" method="POST" class="space-y-5">
        <!-- Selector de área -->
        <div>
          <label class="block text-sm font-semibold text-slate-700 mb-2">Área <span class="text-red-500">*</span></label>
          <div class="grid grid-cols-1 gap-2" id="areas-grid">
            <% areas.forEach(function(area) { %>
            <label class="area-option relative flex items-center gap-3 p-3 rounded-xl border-2 border-slate-200 cursor-pointer transition-all hover:border-primary-300 hover:bg-primary-50/50">
              <input type="radio" name="area_id" value="<%= area.id %>" class="sr-only peer" onchange="seleccionarArea(<%= area.id %>)" required>
              <div class="w-10 h-10 rounded-lg bg-primary-100 text-primary-700 flex items-center justify-center text-sm font-bold shrink-0 peer-checked:bg-primary-600 peer-checked:text-white transition-colors">
                <%= area.nombre.charAt(area.nombre.length - 1) %>
              </div>
              <div class="flex-1">
                <p class="text-sm font-semibold text-slate-800"><%= area.nombre %></p>
                <p class="text-[11px] text-slate-400"><%= area.carreras ? area.carreras.length : 0 %> carrera(s) disponible(s)</p>
              </div>
              <div class="w-5 h-5 rounded-full border-2 border-slate-300 flex items-center justify-center shrink-0 peer-checked:border-primary-600 peer-checked:bg-primary-600 transition-colors">
                <svg class="w-3 h-3 text-white hidden peer-checked:block" fill="currentColor" viewBox="0 0 16 16"><path d="M13.854 3.646a.5.5 0 010 .708l-7 7a.5.5 0 01-.708 0l-3.5-3.5a.5.5 0 11.708-.708L6.5 10.293l6.646-6.647a.5.5 0 01.708 0z"/></svg>
              </div>
            </label>
            <% }); %>
          </div>
        </div>

        <!-- Selector de carrera -->
        <div id="carrera-container" class="hidden">
          <label class="block text-sm font-semibold text-slate-700 mb-2">Carrera referencial <span class="text-xs font-normal text-slate-400">(opcional)</span></label>
          <select name="carrera_id" id="carrera-select" class="w-full px-4 py-2.5 rounded-xl border-2 border-slate-200 text-sm text-slate-700 focus:border-primary-500 focus:ring-2 focus:ring-primary-100 transition-colors outline-none">
            <option value="">Seleccionar carrera...</option>
          </select>
          <p class="text-[11px] text-slate-400 mt-1.5">Si no encuentras tu carrera, solo selecciona el área.</p>
        </div>

        <!-- Botón -->
        <button type="submit" class="w-full py-3 px-4 bg-primary-600 hover:bg-primary-700 text-white font-semibold rounded-xl transition-colors shadow-lg shadow-primary-600/20 flex items-center justify-center gap-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          Confirmar selección
        </button>
      </form>
    </div>

    <p class="text-center text-primary-300 text-xs mt-4">I.E. José Carlos Mariátegui — PIU Mariátegui</p>
  </div>

  <!-- Datos de carreras por área -->
  <script>
    const carrerasPorArea = {};
    <% areas.forEach(function(area) { %>
    carrerasPorArea[<%= area.id %>] = [
      <% if (area.carreras) { area.carreras.forEach(function(c) { %>
      { id: <%= c.id %>, nombre: <%- JSON.stringify(c.nombre) %> },
      <% }); } %>
    ];
    <% }); %>

    function seleccionarArea(areaId) {
      // Estilos de selección (complementa peer-checked de CSS)
      document.querySelectorAll('.area-option').forEach(function(el) {
        var radio = el.querySelector('input[type="radio"]');
        if (radio.checked) {
          el.classList.remove('border-slate-200');
          el.classList.add('border-primary-500', 'bg-primary-50');
        } else {
          el.classList.add('border-slate-200');
          el.classList.remove('border-primary-500', 'bg-primary-50');
        }
      });

      // Mostrar carreras del área
      var container = document.getElementById('carrera-container');
      var select = document.getElementById('carrera-select');
      var carreras = carrerasPorArea[areaId] || [];

      select.innerHTML = '<option value="">Seleccionar carrera...</option>';
      carreras.forEach(function(c) {
        var opt = document.createElement('option');
        opt.value = c.id;
        opt.textContent = c.nombre;
        select.appendChild(opt);
      });

      if (carreras.length > 0) {
        container.classList.remove('hidden');
      } else {
        container.classList.add('hidden');
      }
    }
  </script>
</body>
</html>
