<!-- Evolución -->
<div class="hidden lg:block mb-8">
  <h1 class="text-2xl font-bold text-slate-800">Mi Evolución</h1>
  <p class="text-slate-500 mt-1">Seguimiento de tu progreso a lo largo del tiempo — <span class="text-primary-600 font-medium"><%= estudiante.seccion ? estudiante.seccion.nombre : '' %></span></p>
</div>

<% if (totalResultados === 0) { %>
<div class="card text-center py-12">
  <svg class="w-16 h-16 mx-auto text-slate-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
  <h3 class="text-lg font-medium text-slate-600">Sin datos de evolución</h3>
  <p class="text-sm text-slate-400 mt-1">Necesitas al menos un examen para ver tu gráfico de evolución.</p>
</div>
<% } else { %>

<!-- Gráfico principal de notas -->
<div class="card mb-6">
  <div class="flex items-center justify-between mb-4">
    <h3 class="text-sm font-semibold text-slate-700">Evolución de Notas</h3>
    <div class="flex items-center gap-4 text-xs">
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-primary-500"></span> Mi nota</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-slate-400"></span> Promedio general</span>
      <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-full bg-green-400"></span> Promedio sección</span>
    </div>
  </div>
  <div class="relative" style="height: 350px;">
    <canvas id="chartEvolucion"></canvas>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
  <!-- Gráfico de respuestas -->
  <div class="card">
    <h3 class="text-sm font-semibold text-slate-700 mb-4">Distribución de Respuestas por Examen</h3>
    <div class="relative" style="height: 300px;">
      <canvas id="chartRespuestas"></canvas>
    </div>
  </div>

  <!-- Gráfico de puntaje bruto -->
  <div class="card">
    <h3 class="text-sm font-semibold text-slate-700 mb-4">Puntaje Bruto por Examen</h3>
    <div class="relative" style="height: 300px;">
      <canvas id="chartPuntaje"></canvas>
    </div>
  </div>
</div>

<!-- Tabla comparativa -->
<div class="card">
  <h3 class="text-sm font-semibold text-slate-700 mb-4">Detalle Comparativo</h3>
  <div class="overflow-x-auto">
    <table class="w-full" id="tablaDetalle">
      <thead>
        <tr class="border-b border-slate-200">
          <th class="table-header">Examen</th>
          <th class="table-header text-right">Mi Nota</th>
          <th class="table-header text-right">Prom. General</th>
          <th class="table-header text-right">Prom. Sección</th>
          <th class="table-header text-right">Diferencia</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100" id="tbodyDetalle">
      </tbody>
    </table>
  </div>
</div>
<% } %>

<% if (totalResultados > 0) { %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
(function() {
  const resultados = <%- resultados %>;
  const promediosGenerales = <%- promediosGenerales %>;
  const promediosSeccion = <%- promediosSeccion %>;

  const labels = resultados.map(r => r.examen);
  const notas = resultados.map(r => r.nota);
  const correctas = resultados.map(r => r.correctas);
  const incorrectas = resultados.map(r => r.incorrectas);
  const enBlanco = resultados.map(r => r.en_blanco);
  const puntajes = resultados.map(r => r.puntaje_bruto);

  // Chart defaults
  Chart.defaults.font.family = 'Inter, system-ui, sans-serif';
  Chart.defaults.font.size = 12;
  Chart.defaults.color = '#64748b';

  // === Gráfico de evolución (líneas) ===
  new Chart(document.getElementById('chartEvolucion'), {
    type: 'line',
    data: {
      labels,
      datasets: [
        {
          label: 'Mi nota',
          data: notas,
          borderColor: '#2563eb',
          backgroundColor: 'rgba(37, 99, 235, 0.1)',
          borderWidth: 2.5,
          pointRadius: 5,
          pointHoverRadius: 7,
          pointBackgroundColor: '#2563eb',
          tension: 0.3,
          fill: true
        },
        {
          label: 'Promedio general',
          data: promediosGenerales,
          borderColor: '#94a3b8',
          borderWidth: 1.5,
          pointRadius: 3,
          pointBackgroundColor: '#94a3b8',
          borderDash: [5, 5],
          tension: 0.3,
          fill: false
        },
        {
          label: 'Promedio sección',
          data: promediosSeccion,
          borderColor: '#22c55e',
          borderWidth: 1.5,
          pointRadius: 3,
          pointBackgroundColor: '#22c55e',
          borderDash: [3, 3],
          tension: 0.3,
          fill: false
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      interaction: { intersect: false, mode: 'index' },
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1e293b',
          titleFont: { weight: '600' },
          padding: 12,
          cornerRadius: 8,
          callbacks: {
            label: function(ctx) {
              return ctx.dataset.label + ': ' + ctx.parsed.y.toFixed(2);
            }
          }
        }
      },
      scales: {
        y: {
          min: 0,
          max: 20,
          grid: { color: '#f1f5f9' },
          ticks: { stepSize: 2 }
        },
        x: {
          grid: { display: false },
          ticks: {
            maxRotation: 45,
            font: { size: 10 }
          }
        }
      }
    }
  });

  // === Gráfico de respuestas (barras apiladas) ===
  new Chart(document.getElementById('chartRespuestas'), {
    type: 'bar',
    data: {
      labels,
      datasets: [
        {
          label: 'Correctas',
          data: correctas,
          backgroundColor: '#22c55e',
          borderRadius: 2
        },
        {
          label: 'Incorrectas',
          data: incorrectas,
          backgroundColor: '#ef4444',
          borderRadius: 2
        },
        {
          label: 'En blanco',
          data: enBlanco,
          backgroundColor: '#cbd5e1',
          borderRadius: 2
        }
      ]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: {
          position: 'bottom',
          labels: { boxWidth: 12, padding: 16, font: { size: 11 } }
        },
        tooltip: {
          backgroundColor: '#1e293b',
          padding: 10,
          cornerRadius: 8
        }
      },
      scales: {
        x: {
          stacked: true,
          grid: { display: false },
          ticks: { font: { size: 10 }, maxRotation: 45 }
        },
        y: {
          stacked: true,
          grid: { color: '#f1f5f9' },
          beginAtZero: true
        }
      }
    }
  });

  // === Gráfico de puntaje bruto (barras) ===
  new Chart(document.getElementById('chartPuntaje'), {
    type: 'bar',
    data: {
      labels,
      datasets: [{
        label: 'Puntaje bruto',
        data: puntajes,
        backgroundColor: puntajes.map(p => p >= 0 ? 'rgba(37, 99, 235, 0.7)' : 'rgba(239, 68, 68, 0.7)'),
        borderColor: puntajes.map(p => p >= 0 ? '#2563eb' : '#ef4444'),
        borderWidth: 1,
        borderRadius: 4
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: {
        legend: { display: false },
        tooltip: {
          backgroundColor: '#1e293b',
          padding: 10,
          cornerRadius: 8,
          callbacks: {
            label: function(ctx) {
              return 'Puntaje: ' + ctx.parsed.y.toFixed(2);
            }
          }
        }
      },
      scales: {
        x: {
          grid: { display: false },
          ticks: { font: { size: 10 }, maxRotation: 45 }
        },
        y: {
          grid: { color: '#f1f5f9' },
          beginAtZero: true
        }
      }
    }
  });

  // === Tabla comparativa dinámica ===
  const tbody = document.getElementById('tbodyDetalle');
  resultados.forEach((r, i) => {
    const diff = (r.nota - parseFloat(promediosGenerales[i])).toFixed(2);
    const diffClass = diff >= 0 ? 'text-green-600' : 'text-red-500';
    const diffSign = diff >= 0 ? '+' : '';
    tbody.innerHTML += `
      <tr class="hover:bg-slate-50">
        <td class="table-cell font-medium text-slate-800">${r.examen}<br><span class="text-xs text-slate-400">${r.fecha}</span></td>
        <td class="table-cell text-right font-bold ${r.nota >= 11 ? 'text-green-600' : 'text-red-500'}">${r.nota.toFixed(2)}</td>
        <td class="table-cell text-right text-slate-600">${parseFloat(promediosGenerales[i]).toFixed(2)}</td>
        <td class="table-cell text-right text-slate-600">${parseFloat(promediosSeccion[i]).toFixed(2)}</td>
        <td class="table-cell text-right font-semibold ${diffClass}">${diffSign}${diff}</td>
      </tr>`;
  });
})();
</script>
<% } %>
