<!-- Simulación de Admisión -->
<div class="hidden lg:block mb-8">
  <h1 class="text-2xl font-bold text-slate-800">Simulación de Admisión</h1>
  <p class="text-slate-500 mt-1">Compara tu rendimiento con los puntajes mínimos de admisión</p>
</div>

<!-- Mi información -->
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
  <div class="stat-card">
    <div class="flex items-center justify-between">
      <span class="text-sm font-medium text-slate-500">Mi Puntaje Prom.</span>
      <div class="w-10 h-10 rounded-lg bg-primary-50 text-primary-600 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-slate-800 mt-3"><%= puntajePromedio %></p>
    <p class="text-xs text-slate-400 mt-1">Puntaje bruto promedio</p>
  </div>

  <div class="stat-card">
    <div class="flex items-center justify-between">
      <span class="text-sm font-medium text-slate-500">Nota Promedio</span>
      <div class="w-10 h-10 rounded-lg bg-green-50 text-green-600 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-slate-800 mt-3"><%= promedioGeneral %></p>
    <p class="text-xs text-slate-400 mt-1">Escala vigesimal</p>
  </div>

  <div class="stat-card">
    <div class="flex items-center justify-between">
      <span class="text-sm font-medium text-slate-500">Área</span>
      <div class="w-10 h-10 rounded-lg bg-blue-50 text-blue-600 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
      </div>
    </div>
    <p class="text-xl font-bold text-slate-800 mt-3"><%= estudiante.area ? estudiante.area.nombre : 'Sin área' %></p>
    <p class="text-xs text-slate-400 mt-1"><%= estudiante.carrera ? estudiante.carrera.nombre : 'Sin carrera' %></p>
  </div>

  <div class="stat-card">
    <div class="flex items-center justify-between">
      <span class="text-sm font-medium text-slate-500">Exámenes</span>
      <div class="w-10 h-10 rounded-lg bg-purple-50 text-purple-600 flex items-center justify-center">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
      </div>
    </div>
    <p class="text-3xl font-bold text-slate-800 mt-3"><%= totalExamenes %></p>
    <p class="text-xs text-slate-400 mt-1">Exámenes rendidos</p>
  </div>
</div>

<% if (!estudiante.area) { %>
<!-- Sin área -->
<div class="card-static text-center py-16">
  <div class="icon-box bg-yellow-100 text-yellow-400 mx-auto mb-4 w-16 h-16 rounded-2xl">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/></svg>
  </div>
  <p class="text-sm font-medium text-slate-500">No tienes un área seleccionada</p>
  <p class="text-xs text-slate-400 mt-1 mb-4">Selecciona un área y carrera para ver la simulación de admisión</p>
  <a href="/estudiante/cambiar-carrera" class="btn-primary text-sm">Elegir Área y Carrera</a>
</div>
<% } else if (totalExamenes === 0) { %>
<!-- Sin exámenes -->
<div class="card-static text-center py-16">
  <div class="icon-box bg-primary-100 text-primary-300 mx-auto mb-4 w-16 h-16 rounded-2xl">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
  </div>
  <p class="text-sm font-medium text-slate-500">Aún no tienes exámenes</p>
  <p class="text-xs text-slate-400 mt-1">La simulación estará disponible cuando tengas resultados</p>
</div>
<% } else { %>

<% if (simulaciones.length === 0) { %>
<div class="card-static text-center py-12">
  <p class="text-sm text-slate-500">No hay carreras registradas en tu área para comparar.</p>
</div>
<% } else { %>

<!-- Carreras del área -->
<div class="card-static mb-6">
  <div class="flex items-center gap-2 mb-5">
    <div class="icon-box bg-primary-100 text-primary-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
    </div>
    <div>
      <h2 class="section-title">Simulación — Área: <%= estudiante.area.nombre %></h2>
      <p class="text-xs text-slate-400">Comparación con puntajes mínimos de admisión</p>
    </div>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% simulaciones.forEach(function(sim) { %>
    <div class="rounded-xl border-2 p-5 transition-all <%= sim.es_mi_carrera ? 'border-primary-300 bg-primary-50/30' : 'border-slate-200 bg-white' %>">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h3 class="font-bold text-slate-800 text-sm"><%= sim.nombre %></h3>
          <% if (sim.es_mi_carrera) { %>
          <span class="inline-flex items-center gap-1 text-[11px] font-medium text-primary-600 mt-1">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            Tu carrera
          </span>
          <% } %>
        </div>
        <% if (sim.estado === 'aprobado') { %>
        <span class="badge-green text-xs">✓ Ingresaría</span>
        <% } else if (sim.estado === 'riesgo') { %>
        <span class="badge-yellow text-xs">⚠ En riesgo</span>
        <% } else if (sim.estado === 'desaprobado') { %>
        <span class="badge-red text-xs">✗ No alcanza</span>
        <% } else { %>
        <span class="badge-gray text-xs">Sin datos</span>
        <% } %>
      </div>

      <div class="space-y-3">
        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-xs text-slate-500">Tu puntaje promedio</span>
            <span class="text-sm font-bold text-slate-800"><%= sim.mi_puntaje.toFixed(2) %></span>
          </div>
          <div class="w-full bg-slate-100 rounded-full h-2.5">
            <% const maxPuntaje = Math.max(sim.puntaje_minimo, sim.mi_puntaje, 1); %>
            <% const pctMio = Math.min((sim.mi_puntaje / maxPuntaje) * 100, 100); %>
            <% if (sim.estado === 'aprobado') { %>
            <div class="h-full rounded-full bg-emerald-500" style="width: <%= pctMio %>%"></div>
            <% } else if (sim.estado === 'riesgo') { %>
            <div class="h-full rounded-full bg-yellow-500" style="width: <%= pctMio %>%"></div>
            <% } else { %>
            <div class="h-full rounded-full bg-red-500" style="width: <%= pctMio %>%"></div>
            <% } %>
          </div>
        </div>

        <div>
          <div class="flex items-center justify-between mb-1">
            <span class="text-xs text-slate-500">Puntaje mínimo</span>
            <span class="text-sm font-bold text-slate-500"><%= sim.puntaje_minimo > 0 ? sim.puntaje_minimo.toFixed(2) : 'No definido' %></span>
          </div>
          <% if (sim.puntaje_minimo > 0) { %>
          <div class="w-full bg-slate-100 rounded-full h-2.5">
            <% const pctMin = Math.min((sim.puntaje_minimo / maxPuntaje) * 100, 100); %>
            <div class="h-full rounded-full bg-slate-400" style="width: <%= pctMin %>%"></div>
          </div>
          <% } %>
        </div>

        <% if (sim.puntaje_minimo > 0) { %>
        <div class="pt-2 border-t border-slate-100 flex items-center justify-between">
          <span class="text-xs text-slate-400">Diferencia</span>
          <% if (sim.diferencia >= 0) { %>
          <span class="text-sm font-bold text-emerald-600">+<%= sim.diferencia.toFixed(2) %></span>
          <% } else { %>
          <span class="text-sm font-bold text-red-500"><%= sim.diferencia.toFixed(2) %></span>
          <% } %>
        </div>
        <% } %>
      </div>
    </div>
    <% }); %>
  </div>
</div>

<!-- Nota aclaratoria -->
<div class="card-static bg-blue-50/50 border border-blue-200">
  <div class="flex items-start gap-3">
    <svg class="w-5 h-5 text-blue-500 shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/></svg>
    <div>
      <p class="text-sm font-medium text-blue-800">Nota importante</p>
      <p class="text-xs text-blue-600 mt-1">Esta simulación es referencial y se basa en tu puntaje bruto promedio comparado con los puntajes mínimos históricos de admisión. Los resultados reales pueden variar según la universidad y el proceso de admisión vigente.</p>
    </div>
  </div>
</div>

<% } %>
<% } %>
