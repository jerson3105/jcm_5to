<!-- Reportes -->
<div class="hidden lg:block mb-8">
  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-2xl font-extrabold text-slate-800 tracking-tight">Reportes</h1>
      <p class="text-slate-500 mt-1">Estadísticas generales y análisis del rendimiento académico</p>
    </div>
  </div>
</div>

<!-- Stats generales -->
<div class="grid grid-cols-2 lg:grid-cols-5 gap-3 mb-6">
  <div class="card-static !p-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-primary-100 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
      </div>
      <div>
        <p class="text-xs text-slate-500">Estudiantes</p>
        <p class="text-xl font-extrabold text-slate-800"><%= stats.totalEstudiantes %></p>
      </div>
    </div>
  </div>
  <div class="card-static !p-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
      </div>
      <div>
        <p class="text-xs text-slate-500">Padres</p>
        <p class="text-xl font-extrabold text-slate-800"><%= stats.totalPadres %></p>
      </div>
    </div>
  </div>
  <div class="card-static !p-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-purple-100 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
      <div>
        <p class="text-xs text-slate-500">Exámenes</p>
        <p class="text-xl font-extrabold text-slate-800"><%= stats.totalExamenes %></p>
      </div>
    </div>
  </div>
  <div class="card-static !p-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl bg-gold-100 flex items-center justify-center shrink-0">
        <svg class="w-5 h-5 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>
      <div>
        <p class="text-xs text-slate-500">Resultados</p>
        <p class="text-xl font-extrabold text-slate-800"><%= stats.totalResultados %></p>
      </div>
    </div>
  </div>
  <div class="card-static !p-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl flex items-center justify-center shrink-0 <%= parseFloat(stats.promedioGlobal) >= 11 ? 'bg-emerald-100' : 'bg-red-100' %>">
        <svg class="w-5 h-5 <%= parseFloat(stats.promedioGlobal) >= 11 ? 'text-emerald-600' : 'text-red-500' %>" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
      </div>
      <div>
        <p class="text-xs text-slate-500">Promedio</p>
        <% if (parseFloat(stats.promedioGlobal) >= 11) { %>
        <p class="text-xl font-extrabold text-emerald-600"><%= stats.promedioGlobal %></p>
        <% } else { %>
        <p class="text-xl font-extrabold text-red-500"><%= stats.promedioGlobal %></p>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Gráficos -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
  <!-- Evolución por examen -->
  <div class="card-static">
    <div class="flex items-center gap-2 mb-4">
      <div class="icon-box bg-primary-100 text-primary-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg>
      </div>
      <h3 class="section-title">Evolución de Promedios</h3>
    </div>
    <div class="relative" style="height: 280px;">
      <canvas id="chartEvolucion"></canvas>
    </div>
  </div>

  <!-- Distribución de notas -->
  <div class="card-static">
    <div class="flex items-center gap-2 mb-4">
      <div class="icon-box bg-purple-100 text-purple-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/></svg>
      </div>
      <h3 class="section-title">Distribución de Notas</h3>
    </div>
    <div class="relative" style="height: 280px;">
      <canvas id="chartDistribucion"></canvas>
    </div>
  </div>
</div>

<!-- Secciones y promedios -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
  <!-- Estudiantes por sección -->
  <div class="card-static">
    <div class="flex items-center gap-2 mb-4">
      <div class="icon-box bg-sky-100 text-sky-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <h3 class="section-title">Estudiantes por Sección</h3>
    </div>
    <% if (secciones.length === 0) { %>
    <div class="text-center py-8">
      <p class="text-sm text-slate-400">No hay secciones registradas.</p>
    </div>
    <% } else { %>
    <div class="space-y-3">
      <% const maxEst = Math.max(...secciones.map(x => parseInt(x.total_estudiantes) || 0), 1); %>
      <% secciones.forEach(function(s) { 
        const total = parseInt(s.total_estudiantes) || 0;
        const pct = (total / maxEst * 100).toFixed(0);
      %>
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-md bg-sky-100 text-sky-600 flex items-center justify-center text-[10px] font-bold shrink-0"><%= s.nombre.charAt(s.nombre.length - 1) %></div>
            <span class="text-sm font-medium text-slate-700"><%= s.nombre %></span>
          </div>
          <span class="text-sm font-bold text-slate-800"><%= total %></span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-2">
          <div class="bg-sky-500 rounded-full h-2" style="width: <%= pct %>%"></div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>

  <!-- Promedios por sección -->
  <div class="card-static">
    <div class="flex items-center gap-2 mb-4">
      <div class="icon-box bg-gold-100 text-gold-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
      </div>
      <h3 class="section-title">Promedio por Sección</h3>
    </div>
    <% if (promediosPorSeccion.length === 0) { %>
    <div class="text-center py-8">
      <p class="text-sm text-slate-400">Sin resultados aún.</p>
    </div>
    <% } else { %>
    <div class="space-y-3">
      <% promediosPorSeccion.forEach(function(ps) { 
        const prom = parseFloat(ps.promedio);
        const pct = (prom / 20 * 100).toFixed(0);
      %>
      <div>
        <div class="flex items-center justify-between mb-1.5">
          <div class="flex items-center gap-2">
            <div class="w-6 h-6 rounded-md flex items-center justify-center text-[10px] font-bold shrink-0
              <%= prom >= 14 ? 'bg-emerald-100 text-emerald-600' : prom >= 11 ? 'bg-gold-100 text-gold-600' : 'bg-red-100 text-red-500' %>">
              <%= ps.estudiante.seccion.nombre.charAt(ps.estudiante.seccion.nombre.length - 1) %>
            </div>
            <span class="text-sm font-medium text-slate-700"><%= ps.estudiante.seccion.nombre %></span>
          </div>
          <% if (prom >= 14) { %>
          <span class="text-sm font-bold text-emerald-600"><%= prom.toFixed(2) %></span>
          <% } else if (prom >= 11) { %>
          <span class="text-sm font-bold text-gold-600"><%= prom.toFixed(2) %></span>
          <% } else { %>
          <span class="text-sm font-bold text-red-500"><%= prom.toFixed(2) %></span>
          <% } %>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-2">
          <% if (prom >= 14) { %>
          <div class="bg-emerald-500 rounded-full h-2" style="width: <%= pct %>%"></div>
          <% } else if (prom >= 11) { %>
          <div class="bg-gold-500 rounded-full h-2" style="width: <%= pct %>%"></div>
          <% } else { %>
          <div class="bg-red-500 rounded-full h-2" style="width: <%= pct %>%"></div>
          <% } %>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>

<!-- Top 10 y En Riesgo -->
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 mb-4">
  <!-- Top 10 -->
  <div class="card-static">
    <div class="flex items-center gap-2 mb-4">
      <div class="icon-box bg-gold-100 text-gold-600">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
      </div>
      <h3 class="section-title">Top 10 Estudiantes</h3>
    </div>
    <% if (top10Data.length === 0) { %>
    <div class="text-center py-8">
      <div class="icon-box bg-slate-100 text-slate-300 mx-auto mb-3 w-12 h-12 rounded-2xl">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/></svg>
      </div>
      <p class="text-sm text-slate-400">Sin resultados aún.</p>
    </div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="w-full">
        <thead>
          <tr class="border-b border-slate-200">
            <th class="table-header w-10">#</th>
            <th class="table-header">Nombre</th>
            <th class="table-header">Sección</th>
            <th class="table-header text-right">Promedio</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% top10Data.forEach(function(t) { 
            const prom = parseFloat(t.promedio);
          %>
          <tr class="hover:bg-slate-50/80 transition-colors">
            <td class="table-cell">
              <% if (t.posicion === 1) { %>
              <span class="w-7 h-7 rounded-full bg-gold-100 text-gold-700 flex items-center justify-center text-[11px] font-bold">1°</span>
              <% } else if (t.posicion === 2) { %>
              <span class="w-7 h-7 rounded-full bg-slate-200 text-slate-600 flex items-center justify-center text-[11px] font-bold">2°</span>
              <% } else if (t.posicion === 3) { %>
              <span class="w-7 h-7 rounded-full bg-orange-100 text-orange-600 flex items-center justify-center text-[11px] font-bold">3°</span>
              <% } else { %>
              <span class="w-7 h-7 rounded-full bg-slate-50 text-slate-400 flex items-center justify-center text-[11px] font-medium"><%= t.posicion %></span>
              <% } %>
            </td>
            <td class="table-cell">
              <div class="flex items-center gap-2">
                <div class="w-7 h-7 rounded-lg bg-primary-50 text-primary-600 flex items-center justify-center text-[11px] font-bold shrink-0"><%= t.nombre.charAt(0).toUpperCase() %></div>
                <div>
                  <span class="font-semibold text-slate-800 text-sm"><%= t.nombre %></span>
                  <p class="text-[10px] text-slate-400"><%= t.total_examenes %> examen(es)</p>
                </div>
              </div>
            </td>
            <td class="table-cell"><span class="badge-blue text-xs"><%= t.seccion %></span></td>
            <td class="table-cell text-right">
              <% if (prom >= 14) { %>
              <span class="text-sm font-bold text-emerald-600"><%= t.promedio %></span>
              <% } else if (prom >= 11) { %>
              <span class="text-sm font-bold text-gold-600"><%= t.promedio %></span>
              <% } else { %>
              <span class="text-sm font-bold text-red-500"><%= t.promedio %></span>
              <% } %>
            </td>
          </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>

  <!-- En riesgo -->
  <div class="card-static">
    <div class="flex items-center gap-2 mb-4">
      <div class="icon-box bg-red-100 text-red-500">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      </div>
      <h3 class="section-title">En Riesgo (Promedio &lt; 11)</h3>
    </div>
    <% if (riesgoData.length === 0) { %>
    <div class="text-center py-8">
      <div class="icon-box bg-emerald-100 text-emerald-400 mx-auto mb-3 w-12 h-12 rounded-2xl">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
      <p class="text-sm font-medium text-emerald-600">Sin estudiantes en riesgo</p>
      <p class="text-xs text-slate-400 mt-1">Todos los promedios están por encima de 11</p>
    </div>
    <% } else { %>
    <div class="space-y-2.5 max-h-80 overflow-y-auto">
      <% riesgoData.forEach(function(r) { 
        const prom = parseFloat(r.promedio);
        const pct = (prom / 20 * 100).toFixed(0);
      %>
      <div class="p-3 rounded-xl bg-red-50/70 border border-red-100">
        <div class="flex items-center justify-between mb-2">
          <div class="flex items-center gap-2">
            <div class="w-7 h-7 rounded-lg bg-red-100 text-red-500 flex items-center justify-center text-[11px] font-bold shrink-0"><%= r.nombre.charAt(0).toUpperCase() %></div>
            <div>
              <span class="text-sm font-semibold text-slate-800"><%= r.nombre %></span>
              <p class="text-[10px] text-slate-400"><%= r.seccion %> · <%= r.total_examenes %> ex.</p>
            </div>
          </div>
          <span class="text-sm font-bold text-red-600"><%= r.promedio %></span>
        </div>
        <div class="w-full bg-red-100 rounded-full h-1.5">
          <div class="bg-red-500 rounded-full h-1.5" style="width: <%= pct %>%"></div>
        </div>
      </div>
      <% }); %>
    </div>
    <% } %>
  </div>
</div>

<!-- Promedios por área -->
<div class="card-static mb-6">
  <div class="flex items-center gap-2 mb-4">
    <div class="icon-box bg-emerald-100 text-emerald-600">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
    </div>
    <h3 class="section-title">Promedio por Área</h3>
  </div>
  <% if (promediosPorArea.length === 0) { %>
  <div class="text-center py-8">
    <p class="text-sm text-slate-400">Sin resultados aún.</p>
  </div>
  <% } else { %>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
    <% promediosPorArea.forEach(function(pa) { 
      const prom = parseFloat(pa.promedio);
    %>
    <div class="flex items-center gap-3 p-4 rounded-xl border border-slate-100 bg-slate-50/50">
      <div class="w-12 h-12 rounded-xl flex items-center justify-center text-base font-extrabold shrink-0
        <%= prom >= 14 ? 'bg-emerald-100 text-emerald-700' : prom >= 11 ? 'bg-gold-100 text-gold-700' : 'bg-red-100 text-red-600' %>">
        <%= prom.toFixed(1) %>
      </div>
      <div>
        <p class="font-semibold text-slate-800 text-sm"><%= pa.estudiante.area.nombre %></p>
        <p class="text-[11px] text-slate-400"><%= pa.total_resultados %> resultados</p>
      </div>
    </div>
    <% }); %>
  </div>
  <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4"></script>
<script>
(function() {
  Chart.defaults.font.family = 'Inter, system-ui, sans-serif';
  Chart.defaults.font.size = 12;
  Chart.defaults.color = '#64748b';

  // === Evolución por examen ===
  const promediosPorExamen = <%- promediosPorExamen %>;

  if (promediosPorExamen.length > 0) {
    const labels = promediosPorExamen.map(p => p.examen.descripcion || p.examen.tipo + ' ' + p.examen.fecha);
    new Chart(document.getElementById('chartEvolucion'), {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Promedio',
            data: promediosPorExamen.map(p => parseFloat(p.promedio).toFixed(2)),
            borderColor: '#2563eb',
            backgroundColor: 'rgba(37, 99, 235, 0.1)',
            borderWidth: 2.5,
            pointRadius: 5,
            pointBackgroundColor: '#2563eb',
            tension: 0.3,
            fill: true
          },
          {
            label: 'Nota máxima',
            data: promediosPorExamen.map(p => parseFloat(p.nota_maxima).toFixed(2)),
            borderColor: '#22c55e',
            borderWidth: 1.5,
            pointRadius: 3,
            pointBackgroundColor: '#22c55e',
            borderDash: [4, 4],
            tension: 0.3,
            fill: false
          },
          {
            label: 'Nota mínima',
            data: promediosPorExamen.map(p => parseFloat(p.nota_minima).toFixed(2)),
            borderColor: '#ef4444',
            borderWidth: 1.5,
            pointRadius: 3,
            pointBackgroundColor: '#ef4444',
            borderDash: [4, 4],
            tension: 0.3,
            fill: false
          }
        ]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { intersect: false, mode: 'index' },
        plugins: {
          legend: { position: 'bottom', labels: { boxWidth: 12, padding: 16, font: { size: 11 } } },
          tooltip: { backgroundColor: '#1e293b', padding: 10, cornerRadius: 8 }
        },
        scales: {
          y: { min: 0, max: 20, grid: { color: '#f1f5f9' }, ticks: { stepSize: 2 } },
          x: { grid: { display: false }, ticks: { maxRotation: 45, font: { size: 10 } } }
        }
      }
    });
  } else {
    document.getElementById('chartEvolucion').parentElement.innerHTML = '<p class="text-sm text-slate-400 text-center py-12">Sin datos de exámenes aún.</p>';
  }

  // === Distribución de notas ===
  const distribucion = <%- distribucion %>;

  if (distribucion.length > 0) {
    const coloresDistribucion = {
      'Excelente (18-20)': '#22c55e',
      'Bueno (14-17.99)': '#3b82f6',
      'Regular (11-13.99)': '#eab308',
      'Deficiente (6-10.99)': '#f97316',
      'Muy deficiente (0-5.99)': '#ef4444'
    };

    new Chart(document.getElementById('chartDistribucion'), {
      type: 'doughnut',
      data: {
        labels: distribucion.map(d => d.rango),
        datasets: [{
          data: distribucion.map(d => parseInt(d.cantidad)),
          backgroundColor: distribucion.map(d => coloresDistribucion[d.rango] || '#94a3b8'),
          borderWidth: 2,
          borderColor: '#fff'
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: { position: 'bottom', labels: { boxWidth: 12, padding: 12, font: { size: 11 } } },
          tooltip: {
            backgroundColor: '#1e293b', padding: 10, cornerRadius: 8,
            callbacks: {
              label: function(ctx) {
                const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                const pct = ((ctx.parsed / total) * 100).toFixed(1);
                return ctx.label + ': ' + ctx.parsed + ' (' + pct + '%)';
              }
            }
          }
        }
      }
    });
  } else {
    document.getElementById('chartDistribucion').parentElement.innerHTML = '<p class="text-sm text-slate-400 text-center py-12">Sin datos de distribución aún.</p>';
  }
})();
</script>
