<!-- Secciones CRUD -->
<div class="hidden lg:block mb-8">
  <h1 class="text-2xl font-extrabold text-slate-800 tracking-tight">Secciones</h1>
  <p class="text-slate-500 mt-1">Gestiona las secciones del 5to año</p>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <!-- Formulario crear -->
  <div class="lg:col-span-1">
    <div class="card-static">
      <div class="flex items-center gap-2 mb-5">
        <div class="icon-box bg-primary-100 text-primary-600">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
        </div>
        <h2 class="section-title">Nueva Sección</h2>
      </div>
      <form action="/admin/secciones" method="POST" class="space-y-4">
        <div>
          <label for="nombre" class="input-label">Nombre de la sección</label>
          <input type="text" id="nombre" name="nombre" class="input-field" placeholder="Ej: 5to A - Innovadores" required>
        </div>
        <button type="submit" class="btn-primary w-full">
          <svg class="w-4 h-4 inline-block mr-1.5 -mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/></svg>
          Crear Sección
        </button>
      </form>
    </div>
  </div>

  <!-- Lista de secciones -->
  <div class="lg:col-span-2">
    <div class="card-static">
      <div class="flex items-center justify-between mb-5">
        <div class="flex items-center gap-2">
          <div class="icon-box bg-primary-100 text-primary-600">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <h2 class="section-title">Secciones registradas</h2>
        </div>
        <span class="badge-blue"><%= secciones.length %> total</span>
      </div>
      <% if (secciones.length === 0) { %>
        <div class="text-center py-12">
          <div class="icon-box bg-slate-100 text-slate-400 mx-auto mb-3 w-14 h-14 rounded-2xl">
            <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
          </div>
          <p class="text-sm font-medium text-slate-500">No hay secciones registradas</p>
          <p class="text-xs text-slate-400 mt-1">Crea una sección usando el formulario</p>
        </div>
      <% } else { %>
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-slate-200">
                <th class="table-header">Nombre</th>
                <th class="table-header text-center">Estudiantes</th>
                <th class="table-header text-right">Acciones</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
              <% secciones.forEach(seccion => { %>
              <tr class="hover:bg-slate-50/80 transition-colors" id="row-<%= seccion.id %>">
                <!-- Vista normal -->
                <td class="table-cell view-mode" data-id="<%= seccion.id %>">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-lg bg-primary-100 text-primary-700 flex items-center justify-center text-xs font-bold shrink-0">
                      <%= seccion.nombre.substring(0, 2).toUpperCase() %>
                    </div>
                    <span class="font-semibold text-slate-800"><%= seccion.nombre %></span>
                  </div>
                </td>
                <td class="table-cell text-center view-mode" data-id="<%= seccion.id %>">
                  <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-bold bg-primary-50 text-primary-700"><%= seccion.estudiantes ? seccion.estudiantes.length : 0 %></span>
                </td>
                <td class="table-cell text-right view-mode" data-id="<%= seccion.id %>">
                  <div class="flex items-center justify-end gap-1">
                    <button onclick="editRow(<%= seccion.id %>, '<%= seccion.nombre %>')" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:text-primary-600 hover:bg-primary-50 transition-colors" title="Editar">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                    </button>
                    <form action="/admin/secciones/<%= seccion.id %>/delete" method="POST" class="inline" onsubmit="return confirm('¿Eliminar la sección «<%= seccion.nombre %>»?')">
                      <button type="submit" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-400 hover:text-accent-600 hover:bg-accent-50 transition-colors" title="Eliminar">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                      </button>
                    </form>
                  </div>
                </td>
                <!-- Vista edición (oculta) -->
                <td class="table-cell edit-mode hidden" data-id="<%= seccion.id %>" colspan="3">
                  <form action="/admin/secciones/<%= seccion.id %>/update" method="POST" class="flex items-center gap-2">
                    <input type="text" name="nombre" value="<%= seccion.nombre %>" class="input-field flex-1" id="edit-nombre-<%= seccion.id %>" required>
                    <button type="submit" class="w-8 h-8 rounded-lg flex items-center justify-center text-white bg-primary-600 hover:bg-primary-700 transition-colors shrink-0" title="Guardar">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    </button>
                    <button type="button" onclick="cancelEdit(<%= seccion.id %>)" class="w-8 h-8 rounded-lg flex items-center justify-center text-slate-500 bg-slate-100 hover:bg-slate-200 transition-colors shrink-0" title="Cancelar">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                    </button>
                  </form>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script>
function editRow(id, nombre) {
  document.querySelectorAll('.view-mode[data-id="' + id + '"]').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('.edit-mode[data-id="' + id + '"]').forEach(el => el.classList.remove('hidden'));
  document.getElementById('edit-nombre-' + id).focus();
}
function cancelEdit(id) {
  document.querySelectorAll('.view-mode[data-id="' + id + '"]').forEach(el => el.classList.remove('hidden'));
  document.querySelectorAll('.edit-mode[data-id="' + id + '"]').forEach(el => el.classList.add('hidden'));
}
</script>
