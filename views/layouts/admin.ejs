<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — PIU Mariátegui</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
  <style>
    .sidebar-scroll::-webkit-scrollbar { width: 4px; }
    .sidebar-scroll::-webkit-scrollbar-track { background: transparent; }
    .sidebar-scroll::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.15); border-radius: 4px; }
    .sidebar-scroll::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.25); }
    @media print {
      #sidebar, #mobile-header { display: none !important; }
      .lg\:ml-64 { margin-left: 0 !important; }
      body { background: white !important; }
      .print\:hidden { display: none !important; }
      .print\:block { display: block !important; }
    }
  </style>
</head>
<body class="min-h-screen bg-slate-50">
  <!-- Sidebar -->
  <aside id="sidebar" class="fixed inset-y-0 left-0 z-30 w-64 bg-gradient-to-b from-primary-950 to-primary-900 transform transition-transform duration-200 lg:translate-x-0 -translate-x-full shadow-sidebar overflow-y-auto sidebar-scroll">
    <div class="flex flex-col min-h-full">
        <!-- Logo -->
        <div class="flex items-center gap-3 px-5 py-5">
          <img src="/img/logo-blanco.png" alt="PIU Mariátegui" class="w-10 h-10 rounded-xl object-contain">
          <div>
            <span class="text-sm font-bold text-white">PIU Mariátegui</span>
            <span class="block text-xs text-primary-300">Panel Administrativo</span>
          </div>
        </div>

        <div class="mx-4 border-t border-white/10 mb-2"></div>

        <!-- Nav links -->
        <nav class="flex-1 px-3 py-2 space-y-0.5 overflow-y-auto sidebar-scroll">
          <p class="px-4 pt-2 pb-1.5 text-[10px] font-bold uppercase tracking-widest text-primary-400">Principal</p>
          <a href="/admin" class="<%= currentPage === 'dashboard' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h4a1 1 0 011 1v5a1 1 0 01-1 1H5a1 1 0 01-1-1V5zm10 0a1 1 0 011-1h4a1 1 0 011 1v3a1 1 0 01-1 1h-4a1 1 0 01-1-1V5zM4 15a1 1 0 011-1h4a1 1 0 011 1v4a1 1 0 01-1 1H5a1 1 0 01-1-1v-4zm10-1a1 1 0 011-1h4a1 1 0 011 1v5a1 1 0 01-1 1h-4a1 1 0 01-1-1v-5z"/></svg>
            Dashboard
          </a>

          <p class="px-4 pt-4 pb-1.5 text-[10px] font-bold uppercase tracking-widest text-primary-400">Gestión</p>
          <a href="/admin/secciones" class="<%= currentPage === 'secciones' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg>
            Secciones
          </a>
          <a href="/admin/areas" class="<%= currentPage === 'areas' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/></svg>
            Áreas y Carreras
          </a>
          <a href="/admin/estudiantes" class="<%= currentPage === 'estudiantes' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
            Estudiantes
          </a>
          <a href="/admin/padres" class="<%= currentPage === 'padres' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            Padres
          </a>

          <p class="px-4 pt-4 pb-1.5 text-[10px] font-bold uppercase tracking-widest text-primary-400">Académico</p>
          <a href="/admin/examenes" class="<%= currentPage === 'examenes' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Exámenes
          </a>
          <a href="/admin/resultados" class="<%= currentPage === 'resultados' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Resultados
          </a>
          <a href="/admin/rankings" class="<%= currentPage === 'rankings' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
            Rankings
          </a>
          <a href="/admin/reportes" class="<%= currentPage === 'reportes' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
            Reportes
          </a>

          <div class="mx-1 border-t border-white/10 mt-4 mb-2"></div>

          <a href="/admin/configuracion" class="<%= currentPage === 'configuracion' ? 'sidebar-link-active' : 'sidebar-link' %>">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            Configuración
          </a>
        </nav>

        <!-- User info -->
        <div class="px-4 py-4 border-t border-white/10">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl bg-gold-500 text-primary-950 flex items-center justify-center text-sm font-bold shadow-sm">
              <%= user.nombre.charAt(0).toUpperCase() %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-white truncate"><%= user.nombre %></p>
              <p class="text-xs text-primary-300">Administrador</p>
            </div>
            <form action="/logout" method="POST">
              <button type="submit" class="text-primary-400 hover:text-accent-400 transition-colors" title="Cerrar sesión">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
              </button>
            </form>
          </div>
        </div>
    </div>
  </aside>

  <!-- Overlay mobile -->
  <div id="sidebar-overlay" class="fixed inset-0 z-20 bg-black/50 backdrop-blur-sm hidden lg:hidden" onclick="toggleSidebar()"></div>

  <!-- Main content -->
  <div class="min-h-screen lg:ml-64 flex flex-col">
      <!-- Top bar (mobile) -->
      <header id="mobile-header" class="sticky top-0 z-10 bg-white/80 backdrop-blur-md border-b border-slate-200 px-4 py-3 flex items-center gap-4 lg:hidden">
        <button onclick="toggleSidebar()" class="text-slate-600 hover:text-primary-700 transition-colors" aria-label="Abrir menú">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
        <div class="flex items-center gap-2">
          <img src="/img/logo-blanco.png" alt="PIU" class="w-7 h-7 rounded-lg object-contain bg-primary-600">
          <h1 class="text-lg font-bold text-slate-800"><%= title %></h1>
        </div>
      </header>

      <!-- Page content -->
      <main class="flex-1 p-4 lg:p-8">
        <!-- Flash messages -->
        <% if (locals.success) { %>
        <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-700 text-sm" role="alert">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <span class="font-medium"><%= success %></span>
          </div>
        </div>
        <% } %>

        <% if (locals.error) { %>
        <div class="mb-6 p-4 rounded-xl bg-accent-50 border border-accent-200 text-accent-700 text-sm" role="alert">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
            <span class="font-medium"><%= error %></span>
          </div>
        </div>
        <% } %>

        <%- body %>
      </main>
    </div>

  <script>
    function toggleSidebar() {
      const sidebar = document.getElementById('sidebar');
      const overlay = document.getElementById('sidebar-overlay');
      sidebar.classList.toggle('-translate-x-full');
      overlay.classList.toggle('hidden');
    }
  </script>
  <%- script %>
</body>
</html>
